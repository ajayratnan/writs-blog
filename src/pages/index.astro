---
import WritsLayout from "../layouts/WritsLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

/* ✅ FETCH POSTS HERE (FRONTMATTER ONLY) */
const posts = await getCollection("posts");

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<WritsLayout title="WRITS Blog">

<Header />

<main class="max-w-6xl mx-auto px-4 py-12">

  <!-- HERO -->
  <section class="bg-writs-blue text-white rounded-2xl p-10 text-center">
    <h1 class="text-4xl md:text-5xl font-bold">
      WRITS Blog
    </h1>

    <p class="mt-4 text-white/80">
      Legal explainers, CLAT updates, and practical law learning.
    </p>

    <button class="btn-primary mt-6">
      Start Reading
    </button>
  </section>

  <!-- FEATURED ARTICLES -->
  <section class="mt-12">
    <h2 class="text-xl font-semibold text-writs-blue">
      Featured Articles
    </h2>

    <div class="grid md:grid-cols-3 gap-6 mt-6">

      {sortedPosts.map((post) => (
        <a
          href={`/posts/${post.slug}/`}
          class="border border-writs-border p-6 rounded-xl hover:shadow-soft transition"
        >
          <div class="text-xs text-writs-textSoft">
            {post.data.category}
          </div>

          <h3 class="mt-2 font-semibold text-lg">
            {post.data.title}
          </h3>

          <p class="text-sm mt-2 text-writs-textSoft">
            {post.data.description}
          </p>

          <div class="mt-4 text-writs-red font-semibold">
            Read →
          </div>
        </a>
      ))}

    </div>
  </section>

</main>

<Footer />

</WritsLayout>