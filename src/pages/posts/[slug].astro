---
import { getCollection } from "astro:content";
import WritsLayout from "../../layouts/WritsLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<WritsLayout title={post.data.title}>

<Header />

<main class="max-w-4xl mx-auto px-6 py-14">

<div class="mb-10 border-b border-writs-border pb-6">

  <h1 class="text-4xl md:text-5xl font-bold text-writs-blue leading-tight">
    {post.data.title}
  </h1>

  <div class="mt-4 text-sm text-writs-textSoft flex gap-3 flex-wrap">
    <span>{post.data.pubDate.toDateString()}</span>
    <span>•</span>
    <span class="capitalize">{post.data.category}</span>
  </div>

</div>
  <article
  class="prose prose-lg max-w-none mt-10
         prose-headings:text-writs-blue
         prose-a:text-writs-red
         prose-strong:text-writs-black
         prose-p:text-gray-700
         prose-li:text-gray-700
         prose-blockquote:border-writs-red
         prose-blockquote:text-gray-700"
>
  <Content />
</article>

</main>

<Footer />

</WritsLayout>